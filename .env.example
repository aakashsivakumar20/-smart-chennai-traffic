# ========================
# Smart Chennai Traffic System
# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub
# ========================

# Backend
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chennai_traffic
REDIS_URL=redis://localhost:6379

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/traffic
VITE_MAP_CENTER_LAT=13.0827
VITE_MAP_CENTER_LNG=80.2707

# AI Engine
YOLO_MODEL_PATH=ai-engine/models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
CAMERA_FEED_URL=rtsp://your-camera-ip/stream

# Optional: Cloud deployment
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
