# ⚠️ PRODUCTION ENV VARS — set these in the VERCEL DASHBOARD, not in this file.
# This file is just a reference for what to enter.
#
# Go to: Vercel Project → Settings → Environment Variables
#
# Replace <YOUR-RENDER-BACKEND-URL> with your actual Render URL,
# e.g. https://smart-chennai-traffic-backend.onrender.com
# Do NOT leave the angle brackets in — they must be replaced with the real URL.

VITE_API_URL=https://<YOUR-RENDER-BACKEND-URL>
VITE_WS_URL=wss://<YOUR-RENDER-BACKEND-URL>/ws/traffic
