   "source": [
    "# Chennai Traffic Detector\n",
    "Runs YOLOv8 on a YouTube live stream and pushes vehicle counts to the backend.\n",
    "\n",
    "**Before running:** Go to Runtime → Change runtime type → Select **T4 GPU**"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 1 — Install dependencies\n",
    "!pip install ultralytics yt-dlp -q"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 2 — Config\n",
    "# Paste a YouTube live stream URL showing Chennai traffic below\n",
    "# Search YouTube for: 'Chennai traffic live' or 'Chennai CCTV live'\n",
    "YOUTUBE_URL = \"\"  # <-- paste URL here\n",
    "\n",
    "# Which junction is this stream showing?\n",
    "# Options: kathipara, koyambedu, tnagar, annasalai, omr_perungudi,\n",
    "#          omr_sholing, velachery, guindy, porur, tambaram, marina, adyar\n",
    "ZONE_ID = \"kathipara\"\n",
    "\n",
    "BACKEND_URL = \"https://smart-chennai-traffic-backend.onrender.com\""
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 3 — Get the direct stream URL from YouTube\n",
    "import subprocess\n",
    "\n",
    "assert YOUTUBE_URL, \"Paste a YouTube URL in Step 2 first!\"\n",
    "\n",
    "result = subprocess.run(\n",
    "    [\"yt-dlp\", \"-f\", \"best[ext=mp4]/best\", \"-g\", YOUTUBE_URL],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "stream_url = result.stdout.strip().split(\"\\n\")[0]\n",
    "assert stream_url, f\"Could not get stream URL. yt-dlp error: {result.stderr}\"\n",
    "print(\"Stream URL obtained\")"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 4 — Load YOLOv8 nano model\n",
    "from ultralytics import YOLO\n",
    "model = YOLO(\"yolov8n.pt\")\n",
    "print(\"YOLOv8n loaded\")"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Step 5 — Run detection and push to backend\n",
    "import cv2\n",
    "import requests\n",
    "import time\n",
    "from datetime import datetime\n",
    "\n",
    "VEHICLE_CLASSES = {\n",
    "    2: \"car\",\n",
    "    3: \"motorcycle\",\n",
    "    5: \"bus\",\n",
    "    7: \"truck\",\n",
    "}\n",
    "\n",
    "def run_detection(stream_url, zone_id, duration_minutes=120):\n",
    "    cap = cv2.VideoCapture(stream_url)\n",
    "    if not cap.isOpened():\n",
    "        print(\"Failed to open stream — try a different YouTube URL\")\n",
    "        return\n",
    "\n",
    "    print(f\"Detection running on zone: {zone_id}\")\n",
    "    print(f\"Pushing to: {BACKEND_URL}\")\n",
    "\n",
    "    frame_count = 0\n",
    "    end_time = time.time() + duration_minutes * 60\n",
    "    counts = {\"car\": 0, \"motorcycle\": 0, \"bus\": 0, \"truck\": 0, \"auto\": 0}\n",
    "\n",
    "    while time.time() < end_time:\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            print(\"Stream ended or disconnected\")\n",
    "            break\n",
    "\n",
    "        frame_count += 1\n",
    "\n",
    "        # Run YOLO every 10 frames to save GPU\n",
    "        if frame_count % 10 == 0:\n",
    "            results = model(frame, verbose=False)\n",
    "            counts = {\"car\": 0, \"motorcycle\": 0, \"bus\": 0, \"truck\": 0, \"auto\": 0}\n",
    "            for r in results:\n",
    "                for box in r.boxes:\n",
    "                    cls_id = int(box.cls[0])\n",
    "                    if cls_id in VEHICLE_CLASSES:\n",
    "                        label = VEHICLE_CLASSES[cls_id]\n",
    "                        counts[label] += 1\n",
    "\n",
    "        # Push to backend every 30 frames (~every 3 seconds)\n",
    "        if frame_count % 30 == 0:\n",
    "            payload = {\n",
    "                \"zone_id\": zone_id,\n",
    "                \"vehicle_count\": counts,\n",
    "                \"timestamp\": datetime.now().isoformat(),\n",
    "            }\n",
    "            try:\n",
    "                resp = requests.post(\n",
    "                    f\"{BACKEND_URL}/api/traffic/ingest\",\n",
    "                    json=payload,\n",
    "                    timeout=5\n",
    "                )\n",
    "                total = sum(counts.values())\n",
    "                print(f\"Frame {frame_count} | Vehicles: {total} {counts} | Status: {resp.status_code}\")\n",
    "            except Exception as e:\n",
    "                print(f\"Frame {frame_count} | Failed to push: {e}\")\n",
    "\n",
    "    cap.release()\n",
    "    print(\"Detection stopped\")\n",
    "\n",
    "run_detection(stream_url, ZONE_ID)"
   ],
   "outputs": [],
   "execution_count": null
  }
 ]
}"
